<style>
        :root {
            --primary-gold: #f5c518;
            --bg-dark: #121212;
            --card-bg: #1e1e1e;
            --text-light: #ffffff;
            --text-gray: #b3b3b3;
            --danger: #ff4d4d;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background: linear-gradient(rgba(18, 18, 18, 0.95), rgba(18, 18, 18, 0.95)),
                        url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&w=2070');
            background-size: cover;
        }

        .password-container {
            background: var(--card-bg);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.6);
            width: 100%;
            max-width: 400px;
            border-left: 5px solid var(--primary-gold);
        }

        h2 {
            margin-bottom: 10px;
            font-size: 1.6rem;
            color: var(--primary-gold);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        p.subtitle {
            font-size: 0.85rem;
            color: var(--text-gray);
            margin-bottom: 30px;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        label {
            font-size: 0.75rem;
            font-weight: bold;
            color: var(--text-gray);
            text-transform: uppercase;
        }

        input {
            padding: 12px;
            background: #2a2a2a;
            border: 1px solid #333;
            border-radius: 6px;
            color: white;
            font-size: 1rem;
            transition: 0.3s;
        }

        input:focus {
            outline: none;
            border-color: var(--primary-gold);
            background: #333;
        }

        button {
            background: var(--primary-gold);
            color: black;
            border: none;
            padding: 14px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            margin-top: 15px;
            transition: 0.3s;
        }

        button:hover {
            background: #e2b616;
            transform: translateY(-2px);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: var(--text-gray);
            text-decoration: none;
            font-size: 0.85rem;
        }

        .back-link:hover {
            color: white;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="password-container">
        <h2>Security Settings</h2>
        <p class="subtitle">Change your password to keep your account safe.</p>

        <form action="/auth/<%= user._id %>?_method=PUT" method="POST" id="passwordForm">
            <div class="form-group">
                <label>Current Password</label>
                <input
                    type="password"
                    name="oldPassword"
                    placeholder="Enter current password"
                    required
                />
            </div>

            <div class="form-group">
                <label>New Password</label>
                <input
                    type="password"
                    name="newPassword"
                    id="newPassword"
                    placeholder="New password"
                    required
                />
            </div>

            <div class="form-group">
                <label>Confirm New Password</label>
                <input
                    type="password"
                    name="confirmPassword"
                    id="confirmPassword"
                    placeholder="Repeat new password"
                    required
                />
            </div>

            <button type="submit">Update Password</button>
        </form>

        <a href="/" class="back-link">Cancel & Go Home</a>
    </div>
