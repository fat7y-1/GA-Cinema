<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GA Cinema | Sign In</title>
    <style>
      :root {
        --primary-gold: #f5c518;
        --bg-dark: #121212;
        --card-bg: #1e1e1e;
        --text-light: #ffffff;
        --text-gray: #b3b3b3;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: var(--bg-dark);
        color: var(--text-light);
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        /* Optional: Subtle cinematic background */
        background:
          linear-gradient(rgba(18, 18, 18, 0.9), rgba(18, 18, 18, 0.9)),
          url("https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&w=2070");
        background-size: cover;
      }

      .auth-container {
        background: var(--card-bg);
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
        width: 100%;
        max-width: 400px;
        border-top: 5px solid var(--primary-gold);
        text-align: center;
      }

      h2 {
        margin-bottom: 30px;
        font-size: 1.8rem;
        color: var(--primary-gold);
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .form-group {
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      label {
        font-size: 0.85rem;
        color: var(--text-gray);
        font-weight: bold;
        text-transform: uppercase;
      }

      input {
        padding: 14px;
        background: #2a2a2a;
        border: 1px solid #333;
        border-radius: 8px;
        color: white;
        font-size: 1rem;
        transition: 0.3s;
      }

      input:focus {
        outline: none;
        border-color: var(--primary-gold);
        box-shadow: 0 0 10px rgba(245, 197, 24, 0.2);
      }

      button {
        background: var(--primary-gold);
        color: black;
        border: none;
        padding: 15px;
        border-radius: 8px;
        font-weight: bold;
        font-size: 1.1rem;
        cursor: pointer;
        margin-top: 10px;
        transition: 0.3s;
      }

      button:hover {
        background: #e2b616;
        transform: translateY(-2px);
      }

      .footer-links {
        margin-top: 25px;
        font-size: 0.9rem;
        color: var(--text-gray);
      }

      .footer-links a {
        color: var(--primary-gold);
        text-decoration: none;
      }

      .footer-links a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <div class="auth-container">
      <h2>Welcome Back 🎬</h2>
      <p style="color: var(--text-gray); margin-bottom: 30px">
        Sign in to book your next premiere
      </p>

      <form action="/auth/sign-in" method="POST">
        <div class="form-group">
          <label>Email Address</label>
          <input
            type="email"
            name="email"
            placeholder="email@example.com"
            required
          />
        </div>

        <div class="form-group">
          <label>Password</label>
          <input
            type="password"
            name="password"
            placeholder="••••••••"
            required
          />
        </div>

        <button type="submit">Enter</button>
      </form>

      <div class="footer-links">
        Don't have an account? <a href="/auth/sign-up">Sign Up</a><br />
        <a
          href="/"
          style="
            display: inline-block;
            margin-top: 15px;
            font-size: 0.8rem;
            color: #666;
          "
          >← Back to Home</a
        >
      </div>
    </div>
  </body>
</html>
