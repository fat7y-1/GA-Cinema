<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password Updated</title>

    <style>
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #43cea2, #185a9d);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .card {
        background: #fff;
        padding: 40px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        width: 350px;
      }

      .icon {
        font-size: 50px;
        margin-bottom: 15px;
      }

      h2 {
        margin-bottom: 10px;
        color: #333;
      }

      p {
        color: #777;
        margin-bottom: 25px;
      }

      .btn {
        display: inline-block;
        padding: 12px 20px;
        background: #43cea2;
        color: white;
        text-decoration: none;
        border-radius: 10px;
        transition: 0.3s;
      }

      .btn:hover {
        background: #38b293;
      }
    </style>
  </head>

  <body>
    <div class="card">
      <div class="icon">✅</div>

      <h2>
        Your password has been updated,
        <%= user.first %>!
      </h2>

      <p>You can now log in with your new password.</p>

      <a href="/" class="btn">Home page</a>
    </div>
  </body>
</html>
