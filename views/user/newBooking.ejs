<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book Tickets | <%= movie.name %></title>
    <style>
      body {
        font-family: "Segoe UI", sans-serif;
        background-color: #121212;
        color: white;
        margin: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .booking-container {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
      }

      .booking-card {
        background: #1e1e1e;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        max-width: 400px;
        width: 100%;
        text-align: center;
        border-top: 4px solid #f5c518;
      }

      .booking-card h2 {
        color: #f5c518;
        margin-bottom: 10px;
      }

      .movie-info {
        color: #b3b3b3;
        margin-bottom: 25px;
        font-size: 0.9rem;
      }

      .form-group {
        margin-bottom: 25px;
        text-align: left;
      }

      label {
        display: block;
        margin-bottom: 8px;
        font-weight: bold;
        color: #eee;
      }

      input[type="number"] {
        width: 100%;
        padding: 12px;
        border-radius: 6px;
        border: 1px solid #333;
        background: #2a2a2a;
        color: white;
        font-size: 1rem;
        box-sizing: border-box; /* Prevents input from overflowing */
      }

      input:focus {
        outline: none;
        border-color: #f5c518;
      }

      .btn-submit {
        width: 100%;
        padding: 15px;
        background: #f5c518;
        color: black;
        border: none;
        border-radius: 6px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition:
          transform 0.2s,
          background 0.2s;
      }

      .btn-submit:hover {
        background: #e2b616;
        transform: translateY(-2px);
      }

      .cancel-link {
        display: block;
        margin-top: 15px;
        color: #888;
        text-decoration: none;
        font-size: 0.9rem;
      }

      .cancel-link:hover {
        color: #ff4d4d;
      }
    </style>
  </head>
  <body>
    <div class="booking-container">
      <div class="booking-card">
        <h2>Confirm Booking</h2>
        <p class="movie-info">
          Movie: <strong><%= movie.name %></strong><br />
          Available Seats:
          <span style="color: #2ecc71"><%= movie.Tickets %></span>
        </p>

        <form action="/user/newBook/<%= movie._id %>" method="POST">
          <div class="form-group">
            <label for="userTicket">How many tickets?</label>
            <input
              id="userTicket"
              type="number"
              name="userTicket"
              min="1"
              max="<%= movie.Tickets %>"
              placeholder="Enter amount"
              required
            />
          </div>

          <button type="submit" class="btn-submit">
            Confirm & Choose Seats
          </button>
          <a href="/" class="cancel-link">Cancel and go back</a>
        </form>
      </div>
    </div>
  </body>
</html>
