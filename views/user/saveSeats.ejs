<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>GA Cinema | Your Seats</title>
  <style>
    :root {
      --primary-gold: #f5c518;
      --bg-dark: #121212;
      --card-bg: #1e1e1e;
      --my-green: #2ecc71;
      --taken-red: #e74c3c;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: var(--bg-dark);
      color: white;
      margin: 0;
      text-align: center;
    }

    .container {
      max-width: 800px;
      margin: 40px auto;
      background: var(--card-bg);
      padding: 30px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    /* Cinema Screen Visual */
    .screen {
      width: 80%;
      height: 10px;
      background: #fff;
      margin: 20px auto 50px;
      border-radius: 50%;
      box-shadow: 0 10px 20px rgba(255, 255, 255, 0.3);
      position: relative;
    }
    .screen::after {
      content: "SCREEN";
      position: absolute;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 0.7rem;
      letter-spacing: 5px;
      color: #666;
    }

    /* Grid Styling */
    #seat-grid {
      display: grid;
      grid-template-columns: repeat(9, 45px);
      gap: 12px;
      justify-content: center;
      margin-bottom: 40px;
    }

    .seat {
      width: 40px;
      height: 40px;
      background: #444;
      border-radius: 6px 6px 15px 15px; /* Looks like a theater chair */
      line-height: 40px;
      font-size: 0.8rem;
      color: #999;
    }

    .mySeat {
      background: var(--my-green) !important;
      color: white;
      box-shadow: 0 0 15px rgba(46, 204, 113, 0.4);
    }

    .takenSeat {
      background: var(--taken-red) !important;
      opacity: 0.3;
      color: transparent; /* Hides numbers for other people's seats */
    }

    /* Legend */
    .legend {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-bottom: 30px;
      padding: 15px;
      background: rgba(0,0,0,0.2);
      border-radius: 10px;
    }

    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; }
    .dot { width: 15px; height: 15px; border-radius: 3px; }

    .ticket-info {
      border-top: 1px solid #333;
      padding-top: 20px;
    }

    .seat-badge {
      display: inline-block;
      background: var(--my-green);
      color: white;
      padding: 5px 12px;
      border-radius: 20px;
      margin: 5px;
      font-weight: bold;
    }

    .btn-back {
      display: inline-block;
      margin-top: 30px;
      color: var(--primary-gold);
      text-decoration: none;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <%- include("../partials/header.ejs")%>

  <div class="container">
    <h1 style="color: var(--primary-gold); margin-bottom: 5px;"><%= bookedSeat.name %></h1>
    <p style="color: #888; margin-bottom: 40px;">Your Reserved Seating</p>

    <div class="screen"></div>

    <div id="seat-grid">
      <% for(let i=0; i<72; i++) {
          const mySeat = bookedSeat.selectedSeats.includes(i);
          const otherSeat = bookedSeat.movieId.seats.includes(i);
          let seatClass = "seat";
          if(mySeat) seatClass += " mySeat";
          else if (otherSeat) seatClass += " takenSeat";
      %>
        <div class="<%= seatClass %>">
          <%= mySeat ? "✓" : i+1 %>
        </div>
      <% } %>
    </div>

    <div class="legend">
      <div class="legend-item"><div class="dot mySeat"></div> Your Seats</div>
      <div class="legend-item"><div class="dot takenSeat"></div> Occupied</div>
      <div class="legend-item"><div class="dot" style="background:#444"></div> Available</div>
    </div>

    <div class="ticket-info">
      <h3>Your Ticket Numbers:</h3>
      <% bookedSeat.selectedSeats.forEach(s => { %>
        <span class="seat-badge">Seat <%= s + 1 %></span>
      <% }) %>
    </div>

    <a href="/user/userPage" class="btn-back">← Back to Dashboard</a>
  </div>

</body>
</html>
