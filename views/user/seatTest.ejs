<style>
  .seat { width: 30px; height: 30px; background: #ccc; margin: 5px; display: inline-block; cursor: pointer; border-radius: 5px; }
  .blueSelect { background: blue !important; }
  .redSelect { background: red !important; cursor: not-allowed; }
  .container { display: grid; grid-template-columns: repeat(9, 40px); gap: 10px; }
</style>

<body>
  <div id="data" data-ticket-limit="<%= booking.userTicket %>" data-movie-id="<%= booking.movieId._id %>" data-booked-seats="<%= JSON.stringify(bookedSeats) %>"></div>
  <h2>Select your <%= booking.userTicket %> seats</h2>
  <button id="finishBook">Confirm Seats</button>

  <div class="container">
    <% for(let i=0; i < 72; i++) { %>
      <div class="seat" data-index="<%= i %>"></div>
    <% } %>
  </div>

  <script>
    // 1. Get variables from EJS
    const ticketLimit = parseInt(document.getElementById('data').dataset.ticketLimit);
    const movieId = document.getElementById('data').dataset.movieId;
    const bookedSeats = JSON.parse(document.getElementById('data').dataset.bookedSeats);
    let selectedCount = 0;

    const seats = document.querySelectorAll('.seat');
    const finishBtn = document.querySelector('#finishBook');

    // Mark already booked seats as red
    bookedSeats.forEach(index => {
      const seat = document.querySelector(`.seat[data-index="${index}"]`);
      if (seat) {
        seat.classList.add('redSelect');
      }
    });

    // 2. Add click logic
    seats.forEach(seat => {
      seat.addEventListener('click', () => {
        // If seat is already booked (red), do nothing
        if (seat.classList.contains('redSelect')) return;

        // Toggle selection
        if (seat.classList.contains('blueSelect')) {
          seat.classList.remove('blueSelect');
          selectedCount--;
        } else {
          // Check if user hit their limit
          if (selectedCount < ticketLimit) {
            seat.classList.add('blueSelect');
            selectedCount++;
          } else {
            alert(`You can only select ${ticketLimit} seats!`);
          }
        }
      });
    });

    // 3. Confirm Selection
    finishBtn.addEventListener('click', async () => {
  if (selectedCount < ticketLimit) {
    return alert(`Please select all ${ticketLimit} seats!`);
  }

  // 1. Get the indices of the blue seats
  const selectedIndices = [];
  document.querySelectorAll('.blueSelect').forEach(s => {
    selectedIndices.push(parseInt(s.dataset.index));
  });

  // 2. Send them to the server
  const response = await fetch(`/seat/saveSeats/${movieId}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ seats: selectedIndices })
  });

  if (response.ok) {
    alert("Seats saved successfully!");
    window.location.reload(); // Refresh to see the permanent red seats
  } else {
    alert("Error saving seats.");
  }
});
  </script>
</body>
