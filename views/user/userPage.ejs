<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GA Cinema | My Bookings</title>
    <style>
        :root {
            --primary-gold: #f5c518;
            --bg-dark: #121212;
            --card-bg: #1e1e1e;
            --text-light: #ffffff;
            --text-gray: #b3b3b3;
            --danger: #ff4d4d;
            --success: #2ecc71;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            margin: 0;
        }

        .dashboard-container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .page-header {
            border-bottom: 2px solid var(--primary-gold);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        /* Booking Card Style */
        .booking-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .booking-card {
            background: var(--card-bg);
            border-radius: 10px;
            display: flex;
            align-items: center;
            padding: 20px;
            gap: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            transition: 0.2s;
        }

        .booking-card:hover { border-left: 5px solid var(--primary-gold); }

        .booking-card img {
            width: 80px;
            height: 110px;
            object-fit: cover;
            border-radius: 5px;
        }

        .booking-info { flex-grow: 1; }

        .booking-info h3 { margin: 0 0 10px 0; color: var(--primary-gold); }

        .booking-info p { margin: 3px 0; font-size: 0.9rem; color: var(--text-gray); }

        /* Status Badges */
        .badge {
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: bold;
            text-transform: uppercase;
            display: inline-block;
            margin-bottom: 10px;
        }
        .badge-pending { background: #e67e22; color: white; }
        .badge-confirmed { background: var(--success); color: white; }

        /* Action Buttons */
        .actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-width: 150px;
        }

        .btn-dash {
            text-decoration: none;
            padding: 8px 12px;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: bold;
            text-align: center;
            border: none;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-select { background: var(--primary-gold); color: black; }
        .btn-view { background: #3498db; color: white; }
        .btn-delete { background: transparent; color: var(--danger); border: 1px solid var(--danger); }
        .btn-delete:hover { background: var(--danger); color: white; }

        .empty-state {
            text-align: center;
            padding: 50px;
            background: var(--card-bg);
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <%- include("../partials/header.ejs")%>

    <div class="dashboard-container">
        <header class="page-header">
            <% if(user.email === "admin@email.com"){ %>
                <h1>Customer Bookings (Admin)</h1>
            <% } else { %>
                <h1>My Movie Tickets</h1>
            <% } %>
        </header>

        <% if(book.length === 0){ %>
            <div class="empty-state">
                <h3>No bookings found.</h3>
                <p>Ready for a movie night?</p>
                <a href="/" class="btn-dash btn-select" style="display:inline-block; margin-top:15px;">Browse Movies</a>
            </div>
        <% } %>

        <div class="booking-list">
            <% book.forEach((item) => { %>
                <div class="booking-card">
                    <img src="<%= item.picture %>" alt="poster">

                    <div class="booking-info">
                        <% if(!item.isDone) { %>
                            <span class="badge badge-pending">Action Required: Pick Seats</span>
                        <% } else { %>
                            <span class="badge badge-confirmed">Confirmed</span>
                        <% } %>

                        <h3><%= item.name %></h3>
                        <p><strong>Tickets:</strong> <%= item.userTicket %></p>
                        <p><strong>Booked on:</strong> <%= item.createdAt.toLocaleDateString() %></p>

                        <% if(user.email === "admin@email.com" && item.user){ %>
                            <p style="color: #00d4ff;"><strong>User:</strong> <%= item.user.first %> (<%= item.user.email %>)</p>
                        <% } %>
                    </div>

                    <div class="actions">
                        <% if(!item.isDone){ %>
                            <a href="/seat/seatPage/<%= item._id %>" class="btn-dash btn-select">Select Seats</a>

                            <form action="/user/<%= item._id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn-dash btn-delete">Cancel Order</button>
                            </form>
                        <% } else { %>
                            <a href="/seat/viewSeat/<%= item._id %>" class="btn-dash btn-view">View My Seats</a>

                            <form action="/seat/seatCancel/<%= item._id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn-dash btn-delete">Cancel Booking</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>
