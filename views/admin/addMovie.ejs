<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GA Cinema | Add New Movie</title>
    <style>
      :root {
        --primary-gold: #f5c518;
        --bg-dark: #121212;
        --card-bg: #1e1e1e;
        --text-light: #ffffff;
        --text-gray: #b3b3b3;
        --input-bg: #2a2a2a;
      }

      body {
        font-family: "Segoe UI", sans-serif;
        background-color: var(--bg-dark);
        color: var(--text-light);
        margin: 0;
        padding: 40px 20px;
      }

      .admin-container {
        max-width: 600px;
        margin: 0 auto;
        background: var(--card-bg);
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        border-top: 5px solid var(--primary-gold);
      }

      h1 {
        color: var(--primary-gold);
        text-align: center;
        margin-bottom: 30px;
        font-size: 1.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      label {
        font-weight: bold;
        font-size: 0.9rem;
        color: var(--text-gray);
      }

      input,
      textarea {
        padding: 12px;
        background: var(--input-bg);
        border: 1px solid #333;
        border-radius: 6px;
        color: white;
        font-size: 1rem;
        transition: 0.3s;
      }

      input:focus,
      textarea:focus {
        outline: none;
        border-color: var(--primary-gold);
        box-shadow: 0 0 8px rgba(245, 197, 24, 0.2);
      }

      .help-text {
        font-size: 0.75rem;
        color: #666;
        margin-top: -5px;
      }

      button[type="submit"] {
        background: var(--primary-gold);
        color: black;
        border: none;
        padding: 15px;
        border-radius: 6px;
        font-weight: bold;
        font-size: 1.1rem;
        cursor: pointer;
        margin-top: 10px;
        transition: 0.3s;
      }

      button[type="submit"]:hover {
        background: #e2b616;
        transform: translateY(-2px);
      }

      .back-link {
        display: block;
        text-align: center;
        margin-top: 25px;
        color: var(--text-gray);
        text-decoration: none;
        font-size: 0.9rem;
      }

      .back-link:hover {
        color: white;
        text-decoration: underline;
      }

      /* Number input specific style */
      input[type="number"] {
        width: 100px;
      }
    </style>
  </head>
  <body>
    <div class="admin-container">
      <h1>🎬 Add New Movie</h1>

      <form action="./movies" method="POST">
        <div class="form-group">
          <label>Movie Title</label>
          <input
            type="text"
            name="name"
            placeholder="Title of movie"
            required
          />
        </div>

        <div class="form-group">
          <label>Poster Image URL</label>
          <input type="text" name="picture" placeholder="Image URL" required />
        </div>

        <div class="form-group">
          <label>Trailer Embed Code</label>
          <input type="text" name="trailVideo" placeholder="Copy Code URL" />
          <span class="help-text"
            >Copy the full "Embed Code" from YouTube for best results.</span
          >
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea
            name="description"
            rows="5"
            placeholder="Enter movie plot..."
            required
          ></textarea>
        </div>

        <div style="display: flex; gap: 20px">
          <div class="form-group" style="flex: 1">
            <label>Language</label>
            <input type="text" name="language" placeholder="English" required />
          </div>

          <div class="form-group" style="flex: 1">
            <label>Total Tickets</label>
            <input
              type="number"
              name="Tickets"
              min="1"
              max="72"
              value="72"
              required
            />
          </div>
        </div>

        <button type="submit">Create Movie</button>
      </form>

      <a href="/auth/<%= user._id %>/admin" class="back-link"
        >← Back to Admin Dashboard</a
      >
    </div>
  </body>
</html>
