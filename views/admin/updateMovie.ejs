<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GA Cinema | Update <%= movieGet.name %></title>
    <style>
      :root {
        --primary-gold: #f5c518;
        --bg-dark: #121212;
        --card-bg: #1e1e1e;
        --text-light: #ffffff;
        --text-gray: #b3b3b3;
        --input-bg: #2a2a2a;
      }

      body {
        font-family: "Segoe UI", sans-serif;
        background-color: var(--bg-dark);
        color: var(--text-light);
        margin: 0;
        padding: 40px 20px;
      }

      .update-container {
        max-width: 700px;
        margin: 0 auto;
        background: var(--card-bg);
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        border-top: 5px solid var(--primary-gold);
      }

      .header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
      }

      h1 {
        color: var(--primary-gold);
        margin: 0;
        font-size: 1.6rem;
        text-transform: uppercase;
      }

      .current-poster {
        width: 80px;
        border-radius: 4px;
        border: 2px solid #333;
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      label {
        font-weight: bold;
        font-size: 0.85rem;
        color: var(--text-gray);
        text-transform: uppercase;
      }

      input,
      textarea {
        padding: 12px;
        background: var(--input-bg);
        border: 1px solid #333;
        border-radius: 6px;
        color: white;
        font-size: 1rem;
        transition: 0.3s;
      }

      input:focus,
      textarea:focus {
        outline: none;
        border-color: var(--primary-gold);
      }

      .btn-update {
        background: var(--primary-gold);
        color: black;
        border: none;
        padding: 15px;
        border-radius: 6px;
        font-weight: bold;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
      }

      .btn-update:hover {
        background: #e2b616;
        transform: translateY(-2px);
      }

      .btn-cancel {
        display: block;
        text-align: center;
        margin-top: 20px;
        color: var(--text-gray);
        text-decoration: none;
        font-size: 0.9rem;
      }

      .btn-cancel:hover {
        color: white;
      }

      .row {
        display: flex;
        gap: 20px;
      }
      .flex-1 {
        flex: 1;
      }
    </style>
  </head>
  <body>
    <div class="update-container">
      <div class="header-flex">
        <h1>Update Movie</h1>
        <img
          src="<%= movieGet.picture %>"
          alt="Current Poster"
          class="current-poster"
        />
      </div>

      <form
        action="/admin/movies/<%= movieGet._id %>?_method=PUT"
        method="POST"
      >
        <div class="form-group">
          <label>Movie Name</label>
          <input
            type="text"
            name="name"
            value="<%= movieGet.name %>"
            required
          />
        </div>

        <div class="form-group">
          <label>Poster URL</label>
          <input
            type="text"
            name="picture"
            value="<%= movieGet.picture %>"
            required
          />
        </div>

        <div class="form-group">
          <label>Trailer (Embed Code)</label>
          <textarea name="trailVideo" rows="10" required>
<%= movieGet.trailVideo %></textarea
          >
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="6" required>
<%= movieGet.description %></textarea
          >
        </div>

        <div class="row">
          <div class="form-group flex-1">
            <label>Language</label>
            <input
              type="text"
              name="language"
              value="<%= movieGet.language %>"
              required
            />
          </div>

          <div class="form-group flex-1">
            <label>Tickets Stock</label>
            <input
              type="number"
              name="Tickets"
              value="<%= movieGet.Tickets %>"
              min="1"
              max="72"
              required
            />
          </div>
        </div>

        <button type="submit" class="btn-update">Save Changes</button>
      </form>

      <a href="/admin/movies" class="btn-cancel">Discard Changes & Go Back</a>
    </div>
  </body>
</html>
