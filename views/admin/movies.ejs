<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Movies | Admin</title>
  <style>
    :root {
      --primary-gold: #f5c518;
      --bg-dark: #121212;
      --card-bg: #1e1e1e;
      --text-light: #ffffff;
      --danger: #ff4d4d;
      --success: #2ecc71;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      margin: 0;
      padding: 40px 20px;
    }

    .admin-list-container {
      max-width: 1100px;
      margin: 0 auto;
    }

    .header-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 2px solid #333;
    }

    .btn {
      padding: 10px 20px;
      border-radius: 6px;
      font-weight: bold;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: 0.3s;
      font-size: 0.9rem;
    }

    .btn-add { background: var(--success); color: white; }
    .btn-update { background: var(--primary-gold); color: black; margin-bottom: 5px; width: 100%; }
    .btn-delete { background: transparent; color: var(--danger); border: 1px solid var(--danger); width: 100%; }
    .btn-delete:hover { background: var(--danger); color: white; }
    .btn-back { color: var(--primary-gold); text-decoration: none; font-size: 0.9rem; }

    /* Table Styles */
    .movie-table {
      width: 100%;
      border-collapse: collapse;
      background: var(--card-bg);
      border-radius: 12px;
      overflow: hidden;
    }

    th {
      background: #2a2a2a;
      text-align: left;
      padding: 15px;
      color: var(--primary-gold);
      text-transform: uppercase;
      font-size: 0.8rem;
    }

    td {
      padding: 15px;
      border-bottom: 1px solid #333;
      vertical-align: middle;
    }

    .movie-row:hover { background: #252525; }

    .poster-img {
      width: 60px;
      height: 80px;
      object-fit: cover;
      border-radius: 4px;
    }

    .ticket-badge {
      padding: 4px 8px;
      background: #333;
      border-radius: 4px;
      color: var(--success);
      font-weight: bold;
    }

    .movie-title { font-weight: bold; font-size: 1.1rem; }
    .movie-lang { font-size: 0.85rem; color: #888; }

    .no-movies {
      text-align: center;
      padding: 100px;
      background: var(--card-bg);
      border-radius: 12px;
    }
  </style>
</head>
<body>

  <div class="admin-list-container">
    <div class="header-actions">
        <div>
            <a href="/auth/<%= user._id %>/admin" class="btn-back">← Back to Dashboard</a>
            <h1 style="margin: 10px 0 0 0;">Movie Inventory</h1>
        </div>
        <a href="/admin/new" class="btn btn-add">+ Add New Movie</a>
    </div>

    <% if(movies.length === 0){ %>
      <div class="no-movies">
        <h2>No Movies available</h2>
        <p>Your cinema is currently empty.</p>
      </div>
    <% } else { %>
      <table class="movie-table">
        <thead>
          <tr>
            <th>Poster</th>
            <th>Title & Language</th>
            <th>Tickets Available</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% movies.forEach((movie) => { %>
            <tr class="movie-row">
              <td>
                <img src="<%= movie.picture %>" alt="poster" class="poster-img">
              </td>
              <td>
                <div class="movie-title"><%= movie.name %></div>
                <div class="movie-lang"><%= movie.language %></div>
              </td>
              <td>
                <span class="ticket-badge"><%= movie.Tickets %> Left</span>
              </td>
              <td style="width: 150px;">
                <form action="/admin/movies/<%= movie._id %>" method="GET">
                  <button type="submit" class="btn btn-update">Edit</button>
                </form>

                <form action="/admin/<%= movie._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this movie?');">
                  <button type="submit" class="btn btn-delete">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

</body>
</html>
