<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard | GA Cinema</title>
    <style>
      :root {
        --primary-gold: #f5c518;
        --bg-dark: #121212;
        --card-bg: #1e1e1e;
        --text-light: #ffffff;
        --text-gray: #b3b3b3;
      }

      body {
        font-family: "Segoe UI", sans-serif;
        background-color: var(--bg-dark);
        color: var(--text-light);
        margin: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }

      .dashboard-container {
        width: 100%;
        max-width: 900px;
        padding: 20px;
        text-align: center;
      }

      h1 {
        font-size: 2.5rem;
        color: var(--primary-gold);
        margin-bottom: 40px;
        letter-spacing: 2px;
      }

      .grid-menu {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
      }

      .admin-card {
        background: var(--card-bg);
        padding: 40px 20px;
        border-radius: 15px;
        text-decoration: none;
        color: white;
        transition: all 0.3s ease;
        border: 1px solid #333;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
      }

      .admin-card:hover {
        transform: translateY(-10px);
        border-color: var(--primary-gold);
        box-shadow: 0 10px 25px rgba(245, 197, 24, 0.2);
      }

      .icon {
        font-size: 3rem;
        margin-bottom: 10px;
      }

      .admin-card h2 {
        margin: 0;
        font-size: 1.2rem;
        text-transform: uppercase;
      }

      .admin-card p {
        font-size: 0.85rem;
        color: var(--text-gray);
        margin: 0;
      }

      .home-link {
        margin-top: 50px;
        display: inline-block;
        color: var(--text-gray);
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
      }

      .home-link:hover {
        color: var(--primary-gold);
      }
    </style>
  </head>
  <body>
    <div class="dashboard-container">
      <h1>ADMIN PANEL</h1>

      <div class="grid-menu">
        <a href="/admin/movies" class="admin-card">
          <span class="icon">🎬</span>
          <h2>Manage Movies</h2>
          <p>Edit or delete existing listings</p>
        </a>

        <a href="/admin/new" class="admin-card">
          <span class="icon">➕</span>
          <h2>Add New Movie</h2>
          <p>Upload trailers and set tickets</p>
        </a>

        <a href="/user/userPage" class="admin-card">
          <span class="icon">🎟️</span>
          <h2>Customer Bookings</h2>
          <p>View all tickets sold to users</p>
        </a>
      </div>

      <a href="/" class="home-link">← Return to Public Home Page</a>
    </div>
  </body>
</html>
