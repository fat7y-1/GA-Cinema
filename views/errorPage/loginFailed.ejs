<!-- views/errorPage/loginFailed.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GA Cinema | Login Error</title>
  <style>
    :root {
        --primary-gold: #f5c518;
        --bg-dark: #121212;
        --card-bg: #1e1e1e;
        --text-light: #ffffff;
        --text-gray: #b3b3b3;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .error-container {
      background-color: var(--card-bg);
      padding: 40px 60px;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
      max-width: 500px;
    }

    h1 {
      color: var(--primary-gold);
      font-size: 2.5rem;
      margin-bottom: 20px;
    }

    p {
      font-size: 1.1rem;
      color: var(--text-gray);
      margin-bottom: 30px;
    }

    a {
      text-decoration: none;
      color: black;
      background: var(--primary-gold);
      padding: 12px 25px;
      border-radius: 6px;
      font-weight: bold;
      transition: 0.3s;
    }

    a:hover {
      background: #e2b616;
      transform: scale(1.05);
    }
  </style>
</head>
<body>
  <div class="error-container">
    <h1>❌ Login Failed</h1>
    <p>Login failed. Please try again.</p>
    <a href="/auth/sign-in">Go Back to Sign In</a>
  </div>
</body>
</html>
