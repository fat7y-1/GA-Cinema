<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GA Cinema | <%= descMovie.name %></title>
    <style>
      :root {
        --primary-gold: #f5c518;
        --bg-dark: #121212;
        --card-bg: #1e1e1e;
        --text-light: #ffffff;
        --text-gray: #b3b3b3;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: var(--bg-dark);
        color: var(--text-light);
        margin: 0;
        padding-bottom: 50px;
      }

      .container {
        max-width: 1100px;
        margin: 40px auto;
        padding: 0 20px;
      }

      .movie-header {
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
        background: var(--card-bg);
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
      }

      /* Video Section - Makes the trailer responsive */
      .video-section {
        flex: 2;
        min-width: 350px;
        background: #000;
        display: flex;
        align-items: center;
      }

      .video-section iframe {
        width: 100%;
        aspect-ratio: 16 / 9; /* Keeps the movie proportions perfect */
        border: none;
      }

      /* Info Section */
      .info-section {
        flex: 1;
        padding: 30px;
        min-width: 300px;
        display: flex;
        flex-direction: column;
      }

      h1 {
        color: var(--primary-gold);
        margin-top: 0;
        font-size: 2.2rem;
      }

      .meta-data {
        margin: 15px 0;
        padding: 15px 0;
        border-top: 1px solid #333;
        border-bottom: 1px solid #333;
      }

      .label {
        color: var(--primary-gold);
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.8rem;
        display: block;
        margin-bottom: 5px;
      }

      .description {
        line-height: 1.6;
        color: var(--text-gray);
        margin-bottom: 25px;
      }

      .ticket-count {
        font-size: 1.2rem;
        font-weight: bold;
        color: #2ecc71;
        margin-bottom: 25px;
      }

      /* Booking Button */
      .book-btn {
        display: block;
        text-align: center;
        background: var(--primary-gold);
        color: #000;
        text-decoration: none;
        padding: 15px;
        border-radius: 8px;
        font-weight: bold;
        font-size: 1.1rem;
        transition: 0.3s;
      }

      .book-btn:hover {
        background: #e2b616;
        transform: scale(1.02);
      }

      .back-link {
        display: inline-block;
        margin-top: 20px;
        color: var(--text-gray);
        text-decoration: none;
      }

      .back-link:hover {
        color: #fff;
      }

      @media (max-width: 768px) {
        .movie-header {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <%- include("./partials/header.ejs") %>

    <div class="container">
      <a href="/" class="back-link">← Back to Movies</a>

      <div class="movie-header">
        <div class="video-section"><%- descMovie.trailVideo %></div>

        <div class="info-section">
          <h1><%= descMovie.name %></h1>

          <div class="meta-data">
            <span class="label">Language</span>
            <span><%= descMovie.language %></span>
          </div>

          <div class="description">
            <span class="label">Description</span>
            <p><%= descMovie.description %></p>
          </div>

          <div class="ticket-count"><%= descMovie.Tickets %> Tickets Left</div>

          <a href="/user/newBooking/<%= descMovie._id %>" class="book-btn"
            >Book Tickets Now</a
          >
        </div>
      </div>
    </div>
  </body>
</html>
